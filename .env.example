# Throttled SMTP Relay — Environment Variables
# These override config.yaml settings.

# Local SMTP
THROT_LOCAL_HOST=0.0.0.0
THROT_LOCAL_PORT=1025

# Upstream SMTP
UPSTREAM_HOST=smtp.provider.com
UPSTREAM_PORT=587
UPSTREAM_USERNAME=
UPSTREAM_PASSWORD=
UPSTREAM_TLS=starttls

# Throttling
THROT_MIN_DELAY=30
THROT_MAX_DELAY=120

# Queue
THROT_DB_PATH=queue.db
THROT_MAX_QUEUE=10000
THROT_MAX_RETRIES=5

# Bounce
THROT_BOUNCE_ENABLED=true
THROT_BOUNCE_FROM=mailer-daemon@localhost

# Logging
THROT_LOG_LEVEL=INFO
THROT_LOG_FILE=relay.log
